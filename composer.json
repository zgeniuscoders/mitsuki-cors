{
  "name": "mitsuki/cors",
  "type": "lirary",
  "license": "MIT",
  "description": "Official CORS listener for the Mitsuki PHP framework with IP whitelisting support",
  "keywords": [
    "cors",
    "symfony",
    "listener",
    "http",
    "security",
    "ip-whitelist",
    "cidr",
    "mitsuki",
    "micro-framework"
  ],
  "autoload": {
    "psr-4": {
      "Mitsuki\\Listeners\\": "src/",
      "Tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "zgeniusecoders",
      "email": "zgeniusecoders@gmail.com"
    }
  ],
  "minimum-stability": "stable",
  "require-dev": {
    "pestphp/pest": "^4.4",
    "mitsuki/http": "^1.0"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "require": {
    "php": ">=8.1",
    "mitsuki/listener-contracts": "^1.0"
  }
}
